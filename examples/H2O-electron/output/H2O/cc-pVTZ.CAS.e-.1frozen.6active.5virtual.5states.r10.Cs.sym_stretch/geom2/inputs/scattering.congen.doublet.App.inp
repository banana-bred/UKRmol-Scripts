&state
  sname = 'e + H2O - doublet App',
  megul = 721, ! unit to which output is saved
  iscat = 2,  ! no phase correction necessary for target
  iposit = 0, ! positron flag - 0 for electron, -1 for positron
  symtyp = 2, ! D2h, C2v, etc. are of sym. type 2
  qntot  = 2,1,0, ! triplet of numbers, e.g. 1,0,0 means 1 = Singlet, 0 = A1, etc
  nelect = 11, ! number of electrons
  nob  = 98,57, ! total number of orbitals for each symmetry
!  nobe = , ! number of electron orbitals for each symmetry
!  nobp = , ! number of positron orbitals for each symmetry
!  nobv = , ! number of valent orbitals for each symmetry
  nob0 = 11,1, ! number of target orbitals for each symmetry
  nrefo = 2, ! Number of quintets in reforb
  reforb = 0,1,10,0,0, 1,1,1,0,0, ! reference determinant
  lndo = 10000000, ! memory control
  gflag = 1, ! flag to group CSFs based on symmetry (1=on default)
/
&wfngrp
  gname = 'singlet Ap (ORMAS distribution 1/1) x continuum^1',
  qntar = 1,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,10,0,0, 1,1,1,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,6, 0,1,1, 0,2,3, ! orbitals in each shell
  mshl =   0,     0,     1,     1, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
&wfngrp
  gname = 'triplet Ap (ORMAS distribution 1/1) x continuum^1',
  qntar = 3,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,10,0,0, 1,1,1,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,6, 0,1,1, 0,2,3, ! orbitals in each shell
  mshl =   0,     0,     1,     1, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
&wfngrp
  gname = 'singlet App (ORMAS distribution 1/1) x continuum^1',
  qntar = 1,1,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,10,0,0, 1,1,1,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,6, 0,1,1, 0,12,13, ! orbitals in each shell
  mshl =   0,     0,     1,     0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
&wfngrp
  gname = 'triplet App (ORMAS distribution 1/1) x continuum^1',
  qntar = 3,1,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,10,0,0, 1,1,1,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,6, 0,1,1, 0,12,13, ! orbitals in each shell
  mshl =   0,     0,     1,     0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
&wfngrp
  gname = 'L^2: ORMAS distribution 1/2',
  qntar = -1,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,10,0,0, 1,1,1,0,0, ! movable electrons
  ndprod = 2, ! number of sets of shells
  nelecp = 2,9, ! number of electrons in each set
  nshlp  = 1,2,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,6, 0,1,1, ! orbitals in each shell
  mshl =   0,     0,     1, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
&wfngrp
  gname = 'L^2: ORMAS distribution 2/2',
  qntar = -1,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,10,0,0, 1,1,1,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,6, 0,1,1, 0,7,11, ! orbitals in each shell
  mshl =   0,     0,     1,     0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
