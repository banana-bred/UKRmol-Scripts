&swintfin                 ! used by SW_INTERF (see docs/swinterf)
  name = 'e + H2O - doublet Ap',
  mgvn = 0,               ! symmetry, 0 = A1, as in CONGEN
  stot = 2,               ! spin multiplicity 2*S+1
  ntarg = 5,              ! number of target states
  idtarg = 1,5,4,3,2,              ! mapping of target states from order by target congen inputs to energy order as in unit LUTARG = 24 (output of denprop)
  nvo = 0,0,0,0,0,     !  number of virtual orbitals contracted with the continuum per target state in energy order.
  rmatr = 10,           ! R-matrix radius
  ismax = 2,              ! maximum multipole to be retained in expansion of long range potentials
  iposit = 0,            ! positron flag - 0 for electron, -1 for positron
!  last_coeff_saved = 0,      ! subset of coefficients stored in fort.25 (often restricted to continuum ones)
  !ecutoff = -1,             ! energy (Hartree) cut-off to drop target states in the outer region
  luamp = 16,
  luci = 25,
  luchan = 10,
  lurmt = 21,
  icform = 'U',
  irform = 'U',
/
