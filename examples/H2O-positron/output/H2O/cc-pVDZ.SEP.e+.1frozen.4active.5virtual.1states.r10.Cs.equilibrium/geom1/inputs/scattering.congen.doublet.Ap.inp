&state
  sname = 'e + H2O - doublet Ap',
  megul = 720, ! unit to which output is saved
  iscat = 2,  ! no phase correction necessary for target
  iposit = -1, ! positron flag - 0 for electron, -1 for positron
  symtyp = 2, ! D2h, C2v, etc. are of sym. type 2
  qntot  = 2,0,0, ! triplet of numbers, e.g. 1,0,0 means 1 = Singlet, 0 = A1, etc
  nelect = 11, ! number of electrons
  nob  = 192,114, ! total number of orbitals for each symmetry
  nobe = 96,57, ! number of electron orbitals for each symmetry
  nobp = 96,57, ! number of positron orbitals for each symmetry
  nobv = 9,1, ! number of valent orbitals for each symmetry
  nob0 = 9,1, ! number of target orbitals for each symmetry
  nrefo = 1, ! Number of quintets in reforb
  reforb = 0,1,11,0,0, ! reference determinant
  lndo = 10000000, ! memory control
  gflag = 1, ! flag to group CSFs based on symmetry (1=on default)
/
&wfngrp
  gname = 'Ground state x continuum^1',
  qntar = 1,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 1, ! number of reference determinants
  reforg = 0,1,11,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,4, 0,1,1, 0,106,107, ! orbitals in each shell
  mshl =   0,     0,     1,     0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 0,
/
&wfngrp
  gname = 'Ground state x positron-TGT-to-virtual^1',
  qntar = 1,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 1, ! number of reference determinants
  reforg = 0,1,11,0,0, ! movable electrons
  ndprod = 3, ! number of sets of shells
  nelecp = 2,8,1, ! number of electrons in each set
  nshlp  = 1,2,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,4, 0,1,1, 0,97,105, ! orbitals in each shell
  mshl =   0,     0,     1,     0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
  lsquare = 1,
/
&wfngrp
  gname = 'Core valence^-1 x virtual^1 x positron-TGT-to-virtual^1',
  qntar = 1,0,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 1, ! number of reference determinants
  reforg = 0,1,11,0,0, ! movable electrons
  ndprod = 4, ! number of sets of shells
  nelecp = 2,7,1,1, ! number of electrons in each set
  nshlp  = 1,2,1,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,4, 0,1,1, 0,5,9, 0,97,105, ! orbitals in each shell
  mshl =   0,     0,     1,     0,     0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
  lsquare = 1,
/
&wfngrp
  gname = 'Core valence^-1 x virtual^1 x positron-TGT-to-virtual^1',
  qntar = 1,1,0, ! coupling control
  nelecg = 11, ! number of electrons to distribute among configurations
  nrefog = 1, ! number of reference determinants
  reforg = 0,1,11,0,0, ! movable electrons
  ndprod = 4, ! number of sets of shells
  nelecp = 2,7,1,1, ! number of electrons in each set
  nshlp  = 1,2,1,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,2,4, 0,1,1, 0,5,9, 0,58,58, ! orbitals in each shell
  mshl =   0,     0,     1,     0,     1, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
  lsquare = 1,
/
