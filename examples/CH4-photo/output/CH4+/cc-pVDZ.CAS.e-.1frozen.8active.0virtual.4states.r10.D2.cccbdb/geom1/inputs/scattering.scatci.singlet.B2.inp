&input
  megul = 712,  ! input from module CONGEN
  nfte = 812, ! Hamiltonian scratch file
  iposit = 0, ! positron flag - 0 for electron, -1 for positron
  icidg = 1,   ! 0 - do not diagonalize for parallel, 1 - do diagonalise Hamiltonian matrix for serial
  iexpc = 1,   ! prototype CI expansion flag - 1 for scattering calculation
  icitg = 1,   ! CI target flag - 1 = perform CI target contraction
  idiag = 2,   ! matrix element evaluation flag - 2 = do not evaluate pure target integrals
  nftg = 26,    ! CI target vectors switch - 0 = use scattering wavefunctions to generated (phase corrected) target wavefunctions
  ntgsym = 4,  ! number of target state symmetries (>1 in CAS calculations)
  mcont = 2,3,0,1,   ! lambda value ('symmetry') of the continuum orbitals associated with each target state
  notgt = 52,52,60,52,  ! number of continuum orbitals associated with each target symmetry
  numtgt = 1,1,1,1,  ! number of target states for each symmetries
  ntgtf = 1,2,3,4,  ! set number, on unit NFTG, which contains the required target state
  ntgts = 1,1,1,1,  ! sequence number of the state within the set specified by NTGTF to be used as the target state
/
&cinorn
  name = 'CH4+ CI calculation - singlet B2',
  nftw = 25,
!  memp = 2.5,
!  vecstore = 5, ! 1: store continuum coefficients of the eigenvectors only, 5: store all coefficients
!  igh = 1,
  NPFLG(1) = 0, ! no Hamiltonian matrix elements printed
  NPFLG(2) = 0, ! print lowest 20 eigenvalues only
  nciset = 1,
/
