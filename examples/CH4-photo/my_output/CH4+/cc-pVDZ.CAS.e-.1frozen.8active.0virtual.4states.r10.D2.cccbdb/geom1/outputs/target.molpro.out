 method = 'CASSCF'                                                               ! set to HF or CASSCF in scripts
 
 IF (method.eq.'HF') THEN
 
 {hf;
 wf,nelec=9;
 orbprint,1000;
 }
 
 ELSE
 
 {hf;
 wf,nelec=9;
 orbprint,-1;
 }
 
                                                   ! First CASSCF run only for target states for which orbitals should be optimised
 {multi;
 closed,1,0,0,0;
 occ,3,2,2,2;
 wf,nelec=9,sym=2,spin=1; state,1; wf,nelec=9,sym=3,spin=1; state,1; wf,nelec=9,sym=4,spin=1; state,1;
 natorb,print=1000;
 }
 
                                                           ! Second CASSCF run for all target states without orbital optimalisation
                                                                                 !{multi;
                                                                                 !closed,1,0,0,0;
                                                                                 !occ,3,2,2,2;
 !wf,nelec=9,sym=1,spin=1; state,1; wf,nelec=9,sym=2,spin=1; state,1; wf,nelec=9,sym=3,spin=1; state,1; wf,nelec=9,sym=4,spin=1; state,1;
                                                                                 !dont,orbital;
                                                                                 !dm;
                                                                                 !}
 
                                                                                 ! Saving density matrix for radden
                                                                                 !{matrop;
                                                                                 !load,dm,den,2140.2;
                                                                                 !write,dm;}!save,dm,2140.2,DENSITY;}
 
 ENDIF
 
 put,molden,CH4+.molden;

