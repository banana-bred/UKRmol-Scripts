&input
  name = 'e + H2+ - Transition Moments',
  ipol = 0,                     ! controls calculation of dipole polarizabilities, 0 = no calculation
  nftint = 16,            ! input unit with one-electron properties
  nftg  = 25,                   ! (N+1)-electron eigenstate unit for all symmetries
  ntgt = 8,            ! number of CSF expansions used, this is the number of different output files to be read
  nftsor = 710,711,712,713,714,715,716,717,        ! unit numbers with output from CONGEN
  ntgtf = 1,2,3,4,5,6,7,8,          ! defines the set number, on unit NFTG where the CI vectors for this symmetry are to be found.
  ntgtl = 0,0,0,0,0,0,0,0,          ! defines the sequence number, within the set specified by NTGTF, of the last CI vector to be used
  numtgt = 1,        ! number of target states per symmetry (only non-zero values)
  npflg(9) = 1,                 ! prints computed moments
  zlast = .true.,               ! when set to .true. identifies that this card deck is the last in the stack of &INPUT decks.
  nftmt = 667,                  ! output file unit
  isw = 1,                      ! exclude nuclear multipoles (i.e. the field-nuclei interaction)
/
