&state
  sname = 'e + H2+ - singlet B1u',
  megul = 714, ! unit to which output is saved
  iscat = 2,  ! no phase correction necessary for target
  iposit = 0, ! positron flag - 0 for electron, -1 for positron
  symtyp = 2, ! D2h, C2v, etc. are of sym. type 2
  qntot  = 1,4,0, ! triplet of numbers, e.g. 1,0,0 means 1 = Singlet, 0 = A1, etc
  nelect = 2, ! number of electrons
  nob  = 52,27,27,25,27,25,25,9, ! total number of orbitals for each symmetry
!  nobe = , ! number of electron orbitals for each symmetry
!  nobp = , ! number of positron orbitals for each symmetry
!  nobv = , ! number of valent orbitals for each symmetry
  nob0 = 1,0,0,0,0,0,0,0, ! number of target orbitals for each symmetry
  nrefo = 2, ! Number of quintets in reforb
  reforb = 0,1,1,0,0, 4,1,1,1,0, ! reference determinant
  lndo = 10000000, ! memory control
  gflag = 1, ! flag to group CSFs based on symmetry (1=on default)
/
&wfngrp
  gname = 'doublet Ag (ORMAS distribution 1/1) x continuum^1',
  qntar = 2,0,0, ! coupling control
  nelecg = 2, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,1,0,0, 4,1,1,1,0, ! movable electrons
  ndprod = 2, ! number of sets of shells
  nelecp = 1,1, ! number of electrons in each set
  nshlp  = 1,1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, 0,1,2, ! orbitals in each shell
  mshl =   0,     4, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
&wfngrp
  gname = 'L^2: ORMAS distribution 1/1',
  qntar = -1,0,0, ! coupling control
  nelecg = 2, ! number of electrons to distribute among configurations
  nrefog = 2, ! number of reference determinants
  reforg = 0,1,1,0,0, 4,1,1,1,0, ! movable electrons
  ndprod = 1, ! number of sets of shells
  nelecp = 2, ! number of electrons in each set
  nshlp  = 1,  ! number of shells (triplets) in each set
  pqn  = 0,1,1, ! orbitals in each shell
  mshl =   0, ! symmetry of shells above 
  npcupf = 1, ! print coupling information
!  lsquare = 1,
/
