&input
  nftint = 16,  ! input unit with one-electron properties
  nftmt = 24,  ! output unit with target state properties
  nftg = 26,  ! input unit with target eigenvectors
  name = 'H2 - Transition Moments',
  ipol = 2, ! controls calculation of dipole polarizabilities, 0 = no calculation
  ntgt = 7, ! number of CSF expansions used, this is the number of different output files to be read
  nftsor = 710,711,712,713,714,715,716, ! unit numbers with output from CONGEN
  ntgtf = 1,2,3,4,5,6,7, ! defines the set number, on unit NFTG where the CI vectors for this symmetry are to be found.
  ntgtl = 6,2,2,1,2,1,1, ! defines the sequence number, within the set specified by NTGTF, of the last CI vector to be used
  npflg(9) = 1, ! prints computed moments
  zlast = .true., ! when set to .true. identifies that this card deck is the last in the stack of &INPUT decks.
  isw = 0,  ! include (= 0) or exclude (= 1) the nuclear contribution to diagonal properties
/
