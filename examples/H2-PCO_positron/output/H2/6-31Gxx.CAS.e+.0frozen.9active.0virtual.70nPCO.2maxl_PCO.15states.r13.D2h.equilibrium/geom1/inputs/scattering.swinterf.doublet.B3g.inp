&swintfin                 ! used by SW_INTERF (see docs/swinterf)
  name = 'e + H2 - doublet B3g',
  mgvn = 6,               ! symmetry, 0 = A1, as in CONGEN
  stot = 2,               ! spin multiplicity 2*S+1
  ntarg = 15,              ! number of target states
  idtarg = 1,5,6,9,12,15,4,14,3,13,10,2,11,8,7,              ! mapping of target states from order by target congen inputs to energy order as in unit LUTARG = 24 (output of denprop)
  nvo = ,     !  number of virtual orbitals contracted with the continuum per target state in energy order.
  rmatr = 13,           ! R-matrix radius
  ismax = 2,              ! maximum multipole to be retained in expansion of long range potentials
  iposit = -1,            ! positron flag - 0 for electron, -1 for positron
!  last_coeff_saved = 0,      ! subset of coefficients stored in fort.25 (often restricted to continuum ones)
  !ecutoff = -1,             ! energy (Hartree) cut-off to drop target states in the outer region
  luamp = 16,
  luci = 25,
  luchan = 10,
  lurmt = 21,
  icform = 'U',
  irform = 'U',
/
