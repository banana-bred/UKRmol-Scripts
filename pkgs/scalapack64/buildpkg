#!/bin/bash
# Maintainer: banana-bred <j.forer@posteo.net>
# Adapted from the AUR `scalapack` package by Martin Diehl <aur@martin-diehl.net>
# Builds Reference-ScaLAPACK 2.2.3 with ILP64 (8-byte integers) throughout:
#   - Fortran side via -fdefault-integer-8
#   - C/BLACS side via -DInt=long (as documented in upstream README)

# -- source the buildcfg
here="$(cd "$(dirname "$0")" && pwd)"
. "${here}/../buildcfg" || exit 1
cd "$here" || exit 1

_srcname=scalapack
pkgver=2.2.3
url="https://github.com/Reference-ScaLAPACK/scalapack/archive/v${pkgver}/${_srcname}-${pkgver}.tar.gz"
sha512sum_expected='08c6073f8d1295df4f7f2a2449f189a2afb0ce30e94f2bc55613a94fc6404bb60ee5179ecba02641bff8bd4a088a3f621698e03347fddc6b0895bf14a87ca88a'
ball="${_srcname}-${pkgver}.tar.gz"
srcdir="${_srcname}-${pkgver}"
prefix="$SCALAPACK_PFX"

download() {
  [ -e "$ball" ] && return
  curl -fL -o "$ball" "$url"
}

verify() {
  local sha
  sha=$(sha512sum "$ball" | awk '{print $1}')
  if [ "$sha" != "$sha512sum_expected" ] ; then
    echo "Could not verify"
    exit 1
  fi
}

extract() {
  [ -d "$srcdir" ] && return
  tar -xf "$ball"
}

prepare() {
  sed -i 's/cmake_minimum_required(VERSION 2.8)/cmake_minimum_required(VERSION 3.6)/g' "${srcdir}/BLACS/INSTALL/CMakeLists.txt" || exit 1
}

build() {
  "$CMAKE" -S "$srcdir" \
    -B build \
    -D CMAKE_INSTALL_PREFIX:PATH="$prefix" \
    -D BUILD_SHARED_LIBS:BOOL=ON \
    -D SCALAPACK_BUILD_TESTS:BOOL=OFF \
    -D CMAKE_C_COMPILER="$MPICC" \
    -D CMAKE_Fortran_COMPILER="$MPIFORT" \
    -D CMAKE_BUILD_TYPE:STRING=Release \
    -D CMAKE_Fortran_FLAGS:STRING="$FCFLAGS -fdefault-integer-8 -fallow-argument-mismatch" \
    -D CMAKE_C_FLAGS:STRING="$CFLAGS -DInt=long -Wno-implicit-function-declaration" \
    -D CMAKE_C_STANDARD:STRING="17" \
    -D BLAS_LIBRARIES="-L$OPENBLAS_LIB -lopenblas_64" \
    -D LAPACK_LIBRARIES="-L$OPENBLAS_LIB -lopenblas_64" \
    -D MPI_C_COMPILER="$MPICC" \
    -D MPI_Fortran_COMPILER="$MPIFORT" \
    -D MPIEXEC_EXECUTABLE="$MPIEXEC" || exit 1
  make -C build -j"$MAKEJOBS" || exit 1
}

install_local() {
  "$CMAKE" --install build || exit 1
  # -- headers (PBLAS + BLACS)
  install -m 755 -d "$prefix/include" || exit 1
  install -m 644 "$srcdir/PBLAS/SRC/"*.h "$prefix/include/" || exit 1
  install -m 644 "$srcdir/BLACS/SRC/"*.h "$prefix/include/" || exit 1
}

download || exit 1
verify
extract
prepare
build
install_local

cat <<EOF

Done. ScaLAPACK (ILP64) installed to:
  $prefix

Add to your environment:
  export LD_LIBRARY_PATH="$prefix/lib:\$LD_LIBRARY_PATH"
  export LIBRARY_PATH="$prefix/lib:\$LIBRARY_PATH"
  export C_INCLUDE_PATH="$prefix/include:\$C_INCLUDE_PATH"
EOF
