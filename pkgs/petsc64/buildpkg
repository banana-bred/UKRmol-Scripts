# -- source the buildcfg
here="$(cd "$(dirname "$0")" && pwd)"
. "${here}/../buildcfg" || exit 1
cd "$here" || exit 1

_pkgname=petsc
pkgver=3.25.2
url="https://web.cels.anl.gov/projects/petsc/download/release-snapshots/${_pkgname}-${pkgver}.tar.gz"
sha256sum_expected='03fbcfb72e28dbd92eac042faf7a4ba7e75e602fd1c9af0676f78e0a762412ec'
ball="${_pkgname}-${pkgver}.tar.gz"
srcdir="${_pkgname}-${pkgver}"

prefix="$PETSC_PFX"
export PATH="$MPI_HOME/bin:$PATH"
export LD_LIBRARY_PATH="${OPENBLAS_LIB}:${MPI_HOME}/lib:${SCALAPACK_PFX}/${LIBDIR}:$LD_LIBRARY_PATH"

export PETSC_DIR="${here}/${srcdir}"
export PETSC_ARCH=ilp64

download() {
  [ -e "$ball" ] && return
  curl -fL -o "$ball" "$url"
}

verify() {
  local sha
  sha=$(sha256sum "$ball" | awk '{print $1}')
  if [ "$sha" != "$sha256sum_expected" ] ; then
    echo "Could not verify"
    exit 1
  fi
}

extract() {
  [ -d "$srcdir" ] && return
  tar -xf "$ball"
}

build() {
  cd "${here}/${srcdir}" || exit 1

  # -- we only want MPICH64 and OpenBLAS64
  # --with-64-bit-indices=1       --> PetscInt is 64-bit (needed for slepc)
  # --known-64-bit-blas-indices   --> should match libopenblas_64 (INTERFACE64=1)
  ./configure \
    --prefix="${prefix}" \
    --with-64-bit-indices=1 \
    --known-64-bit-blas-indices=1 \
    --with-mpi-ftn-module=mpi \
    --with-precision=double \
    --with-scalar-type=real \
    --with-fortran-bindings=1 \
    --with-cc="$MPICC" \
    --with-cxx="$MPICXX" \
    --with-fc=$MPIFORT \
    --with-blaslapack-lib="${OPENBLAS_LIB}/libopenblas_64.so" \
    --with-shared-libraries=1 \
    --with-debugging=0 \
    COPTFLAGS="-O2" CXXOPTFLAGS="-O2" FOPTFLAGS="-O2" || exit 1

  make PETSC_DIR="$PETSC_DIR" PETSC_ARCH="$PETSC_ARCH" all -d || exit 1
}

install_local() {
  cd "${here}/${srcdir}" || return 1
  make PETSC_DIR="$PETSC_DIR" PETSC_ARCH="$PETSC_ARCH" install
}

check() {
  cd "${here}/${srcdir}"
  make PETSC_DIR="${prefix}" PETSC_ARCH="" check \
    || echo "WARNING: PETSc make check reported issues"
}

download || exit 1
verify
extract
build
install_local
[ "$1" == nocheck ] || check

cat <<the

============================================================================
Done. PETSc (ILP64, 64-bit indices) installed to:
  ${prefix}

Verify it really is 64-bit indices:
  grep PETSC_USE_64BIT_INDICES ${prefix}/include/petscconf.h

Confirm it linked YOUR OpenBLAS(64), not another (system?) one:
  ldd ${prefix}/lib/libpetsc.so | grep -i openblas

Add to your environment:
  export PETSC_DIR="${prefix}"
  export LD_LIBRARY_PATH="${prefix}/lib:\$LD_LIBRARY_PATH"
============================================================================
the
