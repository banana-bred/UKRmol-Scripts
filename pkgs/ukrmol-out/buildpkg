#!/bin/bash
# Maintainer: banana-bred <j.forer@posteo.net>
# #!/bin/bash

# -- source the buildcfg
here="$(cd "$(dirname "$0")" && pwd)"
. "${here}/../buildcfg" || exit 1
cd "$here" || exit 1

_pkgname=ukrmol-out
repo='https://github.com/banana-bred/Ukrmol-out.git'
branch='main'
_minCmake="3.10"

srcdir="${_pkgname}"
prefix="${UKRMOL_OUT_PFX}"

clone() {
  if [ -d "$srcdir" ]; then
    git -C "$srcdir" fetch --all || exit 1
    # -- if a branch is specified above, check it out. Stay on default otherwiser
    if [ -n "$branch" ] ; then
      git -C "$srcdir" checkout "$branch" || exit 1
    fi
    git -C "$srcdir" pull --ff-only || exit 1
  else
    if [ -n "$branch" ]; then
      git clone --branch "$branch" "$repo" "$srcdir" || exit 1
    else
      git clone "$repo" "$srcdir" || exit 1
    fi
  fi
}

prepare() {
  cd "$srcdir"
  shopt -s globstar nullglob # globbign == easy life
  local files=(**/CMakeLists.txt **/TestDriver.cmake)
  local file
  for file in "${files[@]}"; do
    sed -E -i "s/cmake_minimum.*/cmake_minimum_required(VERSION ${_minCmake})/" "$file"
  done
  cd ..
}

path_prepend() {
 case ":${!2}:" in  # current value of 2
  *":$1:"*) ;;  # 1 is in !2, do not prepend
  *) export "$2"="$1${!2:+:${!2}}";;  # if 1 is not in 2, do prepend
 esac
}

build() {
  cd "$srcdir" || exit 1

  # -- make sure the libraries are visible
  path_prepend "${OPENBLAS_LIB}"     LD_LIBRARY_PATH
  path_prepend "${MPI_HOME}/lib"     LD_LIBRARY_PATH
  path_prepend "$SCALAPACK_PFX/lib"  LD_LIBRARY_PATH

  local _cmakeOptions=(
    -D CMAKE_EXE_LINKER_FLAGS="-Wl,-z,noexecstack,-z,relro,-z,now,--as-needed -Wl,-rpath,${OPENBLAS_LIB}:${MPI_HOME}/lib:${SCALAPACK_PFX}/lib"
    -D CMAKE_SHARED_LINKER_FLAGS='-Wl,-z,noexecstack'
    -D CMAKE_POLICY_VERSION_MINIMUM="${_minCmake}"
    -D CMAKE_C_COMPILER="$MPICC"
    -D CMAKE_CXX_COMPILER="$MPICXX"
    -D CMAKE_Fortran_COMPILER="$MPIFORT"
    -D CMAKE_Fortran_FLAGS="-fdefault-integer-8 -I${GBTO_INC}"
    -D LAPACK_LIBRARIES="-L${OPENBLAS_LIB} -lopenblas_64"
    -D BLAS_LIBRARIES="-L${OPENBLAS_LIB} -lopenblas_64"
    -D MPIEXEC_EXECUTABLE="$MPIEXEC"
    -D GBTOLIB_INCLUDE_DIRS="${GBTO_INC}"
    -D GBTOLIB_LIBRARIES="${GBTO_LIB}"
    -D SCALAPACK_LIBRARIES="$SCALAPACK_LIB"
  )
  "$CMAKE" "${_cmakeOptions[@]}" . || exit 1
  make -j"$MAKEJOBS" || exit 1
  cd ..
}

check() {
  cd "$srcdir" || return 1
  if ctest -N 2>/dev/null | grep -q 'Test #'; then
    ctest --output-on-failure || echo "WARNING: tests reported failures"
  fi
  cd ..
}

install_local() {
  cd "$srcdir" || exit 1
  install -d "$prefix/bin" || exit 1
  install -d "$prefix/lib/${_pkgname}" || exit 1
  install -d "$prefix/share/doc/${_pkgname}" || exit 1
  install -Dm755 bin/*   "$prefix/bin/" || exit 1
  install -Dm644 lib/*.a "$prefix/lib/${_pkgname}/" 2>/dev/null || true
  install -Dm644 doc/*   "$prefix/share/doc/${_pkgname}/" 2>/dev/null || true
  cd ..
}

clone
prepare
build
[ "$1" == nocheck ] || check
install_local

cat <<EOF

Done. UKRmol-out (fint64) installed to:
  $prefix

The whole family is ready (I think). Source the environment file to use it in a shell:
  source ${UKRMOL_ROOT}/ukrmolenv
EOF
