#!/bin/bash
# Maintainer: banana-bred <j.forer@posteo.net>
#!/bin/bash

_pkgname=ukrmol-in
repo='https://github.com/banana-bred/Ukrmol-in.git'
branch='3.3.0-patches'
_minCmake="3.10"

srcdir="${_pkgname}"
prefix="${HOME}/.local/ukrmol-in"

# -- fortran ilp64 locations
mpi_home="${HOME}/.local/mpich"
slepc_home="${HOME}/.local/slepc64"
petsc_home="${HOME}/.local/petsc64"
scalapack_home="${HOME}/.local/scalapack64"
openblas_lib="${HOME}/.local/lib"
scalapack_lib="${scalapack_home}/lib/libscalapack.so"

clone() {
  if [ -d "$srcdir" ]; then
    git -C "$srcdir" fetch --all
    git -C "$srcdir" checkout "$branch"
    git -C "$srcdir" pull --ff-only
  else
    git clone --branch "$branch" "$repo" "$srcdir"
  fi
}

prepare() {
  cd "$srcdir"
  shopt -s globstar nullglob
  local files=(**/CMakeLists.txt **/TestDriver.cmake)
  local file
  for file in "${files[@]}"; do
    sed -E -i "s/cmake_minimum.*/cmake_minimum_required(VERSION ${_minCmake})/" "$file"
  done
  cd ..
}

build() {
  cd "$srcdir"
  export LD_LIBRARY_PATH="$HOME/.local/lib:${mpi_home}/lib:${scalapack_home}/lib:$LD_LIBRARY_PATH"
  local _cmakeOptions=(
    -D CMAKE_POLICY_VERSION_MINIMUM="${_minCmake}"
    -D CMAKE_C_COMPILER="${mpi_home}/bin/mpicc"
    -D CMAKE_CXX_COMPILER="${mpi_home}/bin/mpicxx"
    -D CMAKE_Fortran_COMPILER="$mpi_home/bin/mpifort"
    -D CMAKE_Fortran_FLAGS="-fdefault-integer-8 -Dblas64bit -cpp -I${petsc_home}/include -I${slepc_home}/include"
    -D CMAKE_Fortran_FLAGS="-fdefault-integer-8 -Dblas64bit -cpp -I${petsc_home}/include -I${petsc_home}/include/petsc -I${slepc_home}/include -I${slepc_home}/include/slepc"
    -D WITH_SCALAPACK=ON
    -D BLAS_LIBRARIES="-L$openblas_lib -lopenblas_64"
    -D LAPACK_LIBRARIES="-L$openblas_lib -lopenblas_64"
    -D SCALAPACK_LIBRARIES="$scalapack_lib"
    -D MPIEXEC_EXECUTABLE="$mpi_home/bin/mpiexec"
    -D SLEPC_INCLUDE_DIRS="${slepc_home}/include;${petsc_home}/include"
    -D SLEPC_LIBRARIES="${slepc_home}/lib/libslepc.so;${petsc_home}/lib/libpetsc.so"
  )
  cmake "${_cmakeOptions[@]}" .
  make -j"$(nproc)"
  cd ..
}

check() {
  cd "$srcdir"
  ctest -R parallel || echo "WARNING: parallel tests reported failures"
  [ -d ./Testing ] && mv ./Testing TestingParallel
  ctest -R serial || echo "WARNING: cereal tests reported failures"
  [ -d ./Testing ] && mv ./Testing TestingSerial
  cd ..
}

install_local() {
  cd "$srcdir"
  install -d "$prefix/bin"
  install -d "$prefix/lib/${_pkgname}"
  install -d "$prefix/share/doc/${_pkgname}"
  install -d "$prefix/include/${_pkgname}/gbtolib"

  install -Dm755 bin/* "$prefix/bin/"
  install -Dm644 lib/*.a "$prefix/lib/${_pkgname}/"
  # -- outer-region codes will need the GBTO (s)mod files
  install -Dm644 source/gbtolib/mod/*.mod  "$prefix/include/${_pkgname}/gbtolib/"
  install -Dm644 source/gbtolib/mod/*.smod "$prefix/include/${_pkgname}/gbtolib/"
  install -Dm644 doc/* "$prefix/share/doc/${_pkgname}/" 2>/dev/null || true
  cd ..
}

set -e
clone
prepare
build
set +e
[ "$1" == nocheck ] || check
install_local

cat <<EOF

Done. UKRmol-in (fint64) installed to:
  $prefix

Add to your environment:
  export PATH="$prefix/bin:\$PATH"
  export LD_LIBRARY_PATH="$mpi_home/lib:$openblas_lib:${HOME}/.local/scalapack64/lib:\$LD_LIBRARY_PATH"
EOF
