#!/bin/bash
# Maintainer: banana-bred <j.forer@posteo.net>

# -- source the buildcfg
here="$(cd "$(dirname "$0")" && pwd)"
. "${here}/../buildcfg" || exit 1
cd "$here" || exit 1

_pkgname=ukrmol-in
repo='https://github.com/banana-bred/Ukrmol-in.git'
branch='3.3.0-patches'
_minCmake="3.10"

srcdir="${_pkgname}"
prefix="$UKRMOL_IN_PFX"

clone() {
  if [ -d "$srcdir" ]; then
    git -C "$srcdir" fetch --all || exit 1
    git -C "$srcdir" checkout "$branch" || exit 1
    git -C "$srcdir" pull --ff-only || exit 1
  else
    git clone --branch "$branch" "$repo" "$srcdir" || exit 1
  fi
}

prepare() {
  cd "$srcdir" || exit 1
  shopt -s globstar nullglob
  local files=(**/CMakeLists.txt **/TestDriver.cmake)
  local file
  for file in "${files[@]}"; do
    sed -E -i "s/cmake_minimum.*/cmake_minimum_required(VERSION ${_minCmake})/" "$file" || exit 1
  done
  cd .. || exit 1
}

build() {
  cd "$srcdir" || exit 1
  export LD_LIBRARY_PATH="${MPI_HOME}/lib:${OPENBLAS_LIB}:${SCALAPACK_PFX}/${LIBDIR}:$LD_LIBRARY_PATH"
  local _cmakeOptions=(
    -D CMAKE_POLICY_VERSION_MINIMUM="${_minCmake}"
    -D CMAKE_C_COMPILER="$MPICC"
    -D CMAKE_CXX_COMPILER="$MPICXX"
    -D CMAKE_Fortran_COMPILER="$MPIFORT"
    -D CMAKE_Fortran_FLAGS="-fdefault-integer-8 -fallow-argument-mismatch -Dblas64bit -cpp -I${PETSC_PFX}/include -I${PETSC_PFX}/include/petsc -I${SLEPC_PFX}/include -I${SLEPC_PFX}/include/slepc"
    -D WITH_SCALAPACK=ON
    -D BLAS_LIBRARIES="-L$OPENBLAS_LIB -lopenblas_64"
    -D LAPACK_LIBRARIES="-L$OPENBLAS_LIB -lopenblas_64"
    -D SCALAPACK_LIBRARIES="$SCALAPACK_LIB"
    -D MPIEXEC_EXECUTABLE="$MPIEXEC"
    -D SLEPC_INCLUDE_DIRS="${SLEPC_PFX}/include;${PETSC_PFX}/include"
    -D SLEPC_LIBRARIES="${SLEPC_PFX}/lib/libslepc.so;${PETSC_PFX}/lib/libpetsc.so"
  )
 "$CMAKE" "${_cmakeOptions[@]}" . || exit 1
  make -j"$MAKEJOBS" || exit 1
  cd .. || exit 1
}

check() {
  cd "$srcdir"
  ctest -R parallel || echo "WARNING: parallel tests reported failures"
  [ -d ./Testing ] && mv ./Testing TestingParallel
  ctest -R serial || echo "WARNING: cereal tests reported failures"
  [ -d ./Testing ] && mv ./Testing TestingSerial
  cd ..
}

install_local() {
  cd "$srcdir" || exit 1
  install -d "$prefix/bin" || exit 1
  install -d "$prefix/lib/${_pkgname}" || exit 1
  install -d "$prefix/share/doc/${_pkgname}" || exit 1
  install -d "$prefix/include/${_pkgname}/gbtolib" || exit 1

  install -Dm755 bin/* "$prefix/bin/" || exit 1
  install -Dm644 lib/*.a "$prefix/lib/${_pkgname}/" || exit 1
  # -- outer-region codes will need the GBTO (s)mod files
  install -Dm644 source/gbtolib/mod/*.mod  "$prefix/include/${_pkgname}/gbtolib/" || exit 1
  install -Dm644 source/gbtolib/mod/*.smod "$prefix/include/${_pkgname}/gbtolib/" || exit 1
  install -Dm644 doc/* "$prefix/share/doc/${_pkgname}/" 2>/dev/null || true
  cd .. || exit 1
}

clone
prepare
build
[ "$1" == nocheck ] || check
install_local

cat <<EOF

Done. UKRmol-in (fint64) installed to:
  $prefix

Add to your environment:
  export PATH="$prefix/bin:\$PATH"
  export LD_LIBRARY_PATH="${MPI_HOME}/lib:${OPENBLAS_LIB}:${SCALAPACK_PFX}/$LIBDIR:\$LD_LIBRARY_PATH"
EOF
