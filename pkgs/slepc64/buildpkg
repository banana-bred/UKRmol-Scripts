# -- source the buildcfg
here="$(cd "$(dirname "$0")" && pwd)"
. "${here}/../buildcfg" || exit 1
cd "$here" || exit 1

_pkgname=slepc
pkgver=3.25.1
url="https://slepc.upv.es/download/distrib/${_pkgname}-${pkgver}.tar.gz"
sha256sum_expected='906ddbe15a20774c23ddcdf13a5054889d00a26c3c37463447ee593c757d03ee'

ball="${_pkgname}-${pkgver}.tar.gz"
srcdir="${_pkgname}-${pkgver}"

prefix="${SLEPC_PFX}"

export PATH="$MPI_HOME/bin:$PATH"
export LD_LIBRARY_PATH="${MPI_HOME}/lib:${OPENBLAS_LIB}:${PETSC_PFX}/lib:$LD_LIBRARY_PATH"

# -- SLEPc reads PETSc from PETSC_DIR, PETSC_ARCH must be unset to use the prefix
export PETSC_DIR="${PETSC_PFX}"
unset PETSC_ARCH

download() {
  [ -e "$ball" ] && return
  curl -fL -o "$ball" "$url"
}

verify() {
  [ -z "$sha256sum_expected" ] && echo "NOTE: sha empty, skipping verify" && return
  local sha
  sha=$(sha256sum "$ball" | awk '{print $1}')
  if [ "$sha" != "$sha256sum_expected" ] ; then
    echo "Could not verify"
    exit 1
  fi
}

extract() {
  [ -d "$srcdir" ] && return
  tar -xf "$ball"
}

build() {
  cd "${here}/$srcdir" || exit 1
  export SLEPC_DIR="${here}/$srcdir"

  # -- make sure that we're actually using an ILP64 PETSc, because
  #    otherwise what's the point ? Refuse if not !
  if ! grep -q "PETSC_USE_64BIT_INDICES 1" "${PETSC_DIR}/include/petscconf.h" 2>/dev/null; then
    echo "WARNING: ${PETSC_DIR} is not a 64-bit-indices PETSc, or PETSc is not even installed there at all. Maybe stop ?"
    exit 1
  fi

  ./configure --prefix="${prefix}" --with-clean || exit 1

  make SLEPC_DIR="$SLEPC_DIR" PETSC_DIR="${PETSC_DIR}" || exit 1
}

_install() {
  cd "${here}/${srcdir}" || exit 1
  make SLEPC_DIR="${here}/${srcdir}" PETSC_DIR="$PETSC_DIR" install || exit 1
}

check() {
  cd "${here}/${srcdir}" || return 1
  make SLEPC_DIR="${prefix}" PETSC_DIR="${PETSC_DIR}" PETSC_ARCH="" check || echo "WARNING: SLEPc make check reported issues"
}

download || exit 1
verify
extract
build
_install
[ "$1" == nocheck ] || check

cat <<EOF

============================================================================
Done. SLEPc (ILP64, inherited from ${PETSC_PFX}) installed to:
  ${prefix}

Add to your environment:
  export PETSC_DIR="${PETSC_PFX}"
  export SLEPC_DIR="${prefix}"
  export LD_LIBRARY_PATH="${PETSC_PFX}/lib:${prefix}/lib:\$LD_LIBRARY_PATH"

Tell UKRmol+ about it (adjust the names to what the above ls shows):
  -D SLEPC_INCLUDE_DIRS="${PETSC_PFX}/include;${prefix}/include"
  -D SLEPC_LIBRARIES="${prefix}/lib/libslepc.so;${PETSC_PFX}/lib/libpetsc.so"
============================================================================
EOF
