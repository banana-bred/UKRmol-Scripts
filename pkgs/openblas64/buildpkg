#!/bin/bash
# Maintainer: Felix Yan <felixonmars@archlinux.org>
# Contributor: Giuseppe Borzi <gborzi _AT_ ieee _DOT_ org>
_pkgname=OpenBLAS
pkgver=0.3.33
url="https://github.com/OpenMathLib/OpenBLAS/releases/download/v${pkgver}/${_pkgname}-${pkgver}.tar.gz"
sha256sum_expected='6761af1d9f5d353ab4f0b7497be2643313b36c8f31caec0144bfef198e71e6ab'
ball="${_pkgname}-${pkgver}.tar.gz"
srcdir="${_pkgname}-${pkgver}"
prefix="$OPENBLAS_PFX"

# -- source the buildcfg
here="$(cd "$(dirname "$0")" && pwd)"
. "${here}/../buildcfg" || exit 1
cd "$here" || exit 1

download() {
  [ -e "$ball" ] && return
  curl -fL -o "$ball" "$url"
}

verify() {
  local sha
  sha=$(sha256sum "$ball" | awk '{print $1}')
  if [ "$sha" != "$sha256sum_expected" ]; then
    echo "Could not verify $ball" >&2
    exit 1
  fi
}

extract() {
  [ -d "$srcdir" ] && return
  tar -xf "$ball"
}

build() {
  cd "$srcdir" || exit 1
  ASMFLAGS=$CFLAGS FFLAGS=${CFLAGS/ -Wformat -Werror=format-security/} FC=gfortran \
    "$CMAKE" -B build64 -S . \
    -DCMAKE_INSTALL_PREFIX="$prefix" \
    -DCMAKE_INSTALL_LIBDIR="$LIBDIR" \
    -DBUILD_SHARED_LIBS=ON \
    -DBUILD_TESTING=OFF \
    -DNO_AFFINITY=ON \
    -DUSE_OPENMP=1 \
    -DNO_WARMUP=1 \
    -DNUM_THREADS=64 \
    -DDYNAMIC_ARCH=OFF \
    -DINTERFACE64=1 || exit 1
  "$CMAKE" --build build64 -j"$MAKEJOBS" || exit 1
  cd .. || exit 1
}

install_local() {
  cd "$srcdir" || exit 1
  "$CMAKE" --install build64
  cd .. || exit 1
}

download || exit 1
verify
extract || exit 1
build
install_local

cat <<the

Done. OpenBLAS (ILP64) installed to:
  $prefix

Add to your environment if not already there:
  export LD_LIBRARY_PATH="${OPENBLAS_LIB}:\$LD_LIBRARY_PATH"
the
